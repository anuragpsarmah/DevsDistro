VITE_GITHUB_CLIENT_ID=       # GitHub OAuth client ID (string)
VITE_BACKEND_URI=            # Backend server URI (URL string)
VITE_CITIES_API_URI=         # Cities API URI (URL string)
VITE_SOLANA_NETWORK=         # Solana cluster (e.g. mainnet-beta, devnet)
VITE_SOLANA_RPC_URL=         # Optional: custom RPC endpoint (e.g. Helius mainnet URL). Falls back to public cluster RPC if not set.
VITE_SITE_URL=               # Public site origin used for SEO canonicals (e.g. https://devsdistro.com)
