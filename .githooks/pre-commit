#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

needs_recommit=0

run_format_check() {
  project_dir="$1"
  printf '\n[pre-commit] Checking formatting in %s...\n' "$project_dir"

  if npm --prefix "$project_dir" run format:check; then
    return 0
  fi

  printf '[pre-commit] Formatting %s because format:check failed...\n' "$project_dir"
  npm --prefix "$project_dir" run format
  needs_recommit=1
}

run_format_check "frontend"
run_format_check "backend"

if [ "$needs_recommit" -eq 1 ]; then
  cat <<'EOF'

[pre-commit] Formatting updated files.
[pre-commit] Review the changes, stage them, and run commit again.
EOF
  exit 1
fi

printf '\n[pre-commit] Formatting checks passed.\n'
