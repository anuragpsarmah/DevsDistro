/* DATABASE */
MONGODB_URI=                    # MongoDB connection URI (string)
RETRIES=                        # Number of connection retries (integer)
ENCRYPTION_KEY_32=              # 32-byte encryption key (string)

/* AUTH */
GITHUB_CLIENT_ID=               # GitHub OAuth client ID (string)
GITHUB_CLIENT_SECRET=           # GitHub OAuth client secret (string)
GITHUB_REDIRECT_URI=            # OAuth callback URL (must exactly match GitHub app callback URL)
JWT_SECRET=                     # Secret key for JWT (string)
JWT_EXPIRES_IN=15m              # JWT session token lifetime (e.g., "15m", "1h", "3d")

/* PROJECT */
PORT=                           # Port number for the server (integer)
FRONTEND_URI=                   # Hosted frontend URL (string)

/* AWS S3 */
S3_ACCESS_KEY_ID=               # AWS S3 access key ID (string)
S3_SECRET_ACCESS_KEY=           # AWS S3 secret access key (string)
S3_BUCKET=                      # AWS S3 bucket name (string)
S3_CLOUDFRONT_DISTRIBUTION=     # AWS CloudFront distribution domain (string)

/* CONFIGS */
WORKER_CRON_EXPRESSION=         # Schedule for S3Cleanup worker (string)
DEFAULT_PROJECT_LISTING_LIMIT=  # Max projects a user can list (integer, default: 5)

/* SOLANA PAYMENTS */
SOLANA_RPC_URL=                 # Solana RPC endpoint (e.g. https://api.devnet.solana.com or mainnet RPC)
SOLANA_NETWORK=mainnet-beta     # Network identifier: mainnet-beta | devnet | testnet (enables public RPC fallback on mainnet)
SOLANA_TREASURY_WALLET=         # DevsDistro treasury Solana wallet address (receives 1% platform fee)
SOLANA_USDC_MINT=               # Optional override for the USDC mint on the active Solana network
SOLANA_ATA_SPONSOR_SECRET_KEY=  # Platform signer secret for USDC ATA sponsorship (base58 or JSON array)
PLATFORM_FEE_PERCENT=1          # Platform fee percentage taken from each sale (integer, default: 1)

/* FEATURED REVIEW ID */
FEATURED_REVIEW_ID1=            # MongoDB ObjectID of the first featured review (string)
FEATURED_REVIEW_ID2=            # MongoDB ObjectID of the second featured review (string)
FEATURED_REVIEW_ID3=            # MongoDB ObjectID of the third featured review (string)
